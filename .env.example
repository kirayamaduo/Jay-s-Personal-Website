# ── 数据库配置 ──────────────────────────────────────────────────────────────────
# MySQL root 密码（必填，自己设一个强密码）
DB_PASSWORD=your_strong_mysql_password_here

# 数据库名称（默认 tech_portal_pro，一般不用改）
DB_NAME=tech_portal_pro

# ── Redis 配置 ──────────────────────────────────────────────────────────────────
# Redis 密码（可留空，但生产环境建议设置）
REDIS_PASSWORD=your_redis_password_here

# ── JWT 密钥 ────────────────────────────────────────────────────────────────────
# 必须足够长且随机，可用命令生成: openssl rand -base64 64
JWT_SECRET=replace_this_with_a_very_long_random_string_at_least_64_characters_long

# ── CORS（可选）────────────────────────────────────────────────────────────────
# 如果你绑定了自定义域名，把域名填在这里（逗号分隔多个）
# 例如: https://example.com,https://www.example.com
CORS_ALLOWED_ORIGINS=

# ── 端口配置 ────────────────────────────────────────────────────────────────────
# 对外暴露的 HTTP 端口（默认 80）
HTTP_PORT=80
